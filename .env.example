# =============================================================================
# LMU Telemetry Analysis API — Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment.
# Do NOT commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=8000
HOST=0.0.0.0
ENV=development                   # development | staging | production
LOG_LEVEL=info                    # debug | info | warning | error

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///telemetry.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/lmu_telemetry

# -----------------------------------------------------------------------------
# Telemetry Capture
# -----------------------------------------------------------------------------
TELEMETRY_POLL_RATE_MS=10         # How often to read from shared memory (ms)
TELEMETRY_BATCH_SIZE=100          # Frames per batch when sending to API
MAX_BATCH_SIZE=1000               # Max frames accepted per single POST /telemetry

# -----------------------------------------------------------------------------
# Session Management
# -----------------------------------------------------------------------------
SESSION_GAP_THRESHOLD_SECONDS=300 # Time gap (s) that triggers a new session

# -----------------------------------------------------------------------------
# E3N Integration
# -----------------------------------------------------------------------------
E3N_ENABLED=false
E3N_ENDPOINT=http://localhost:3000/ingest
# E3N_API_KEY=                    # If E3N requires auth (future)

# -----------------------------------------------------------------------------
# Alerts
# -----------------------------------------------------------------------------
ALERTS_ENABLED=true
ALERTS_DEFAULT_RULES=true         # Load default alert rules on startup

# -----------------------------------------------------------------------------
# WebSocket
# -----------------------------------------------------------------------------
WS_HEARTBEAT_INTERVAL_S=30       # Keep-alive ping interval for WS connections
