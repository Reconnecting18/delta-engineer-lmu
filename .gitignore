# =============================================================================
# LMU Telemetry Analysis API — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.production
*.pem
*.key

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
.venv/
venv/
env/
*.whl
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/
package-lock.json
# Uncomment if you want to lock deps:
# !package-lock.json

# -----------------------------------------------------------------------------
# Electron / Build Output
# -----------------------------------------------------------------------------
dist/
out/
release/
*.exe
*.dmg
*.AppImage
*.snap
*.deb
*.rpm

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Database (local dev)
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
Desktop.ini
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
test-results/
